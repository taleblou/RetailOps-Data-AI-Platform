# Standard profile: lite + ML + monitoring + operational AI modules
APP_PROFILE=standard
ENABLE_CONNECTOR_CSV=true
ENABLE_ANALYTICS_KPI=true
ENABLE_FORECASTING=true
ENABLE_SHIPMENT_RISK=true
ENABLE_STOCKOUT_INTELLIGENCE=true
ENABLE_REORDER_ENGINE=true
ENABLE_RETURNS_INTELLIGENCE=true
ENABLE_MONITORING=true
ENABLE_CDC=false
ENABLE_LAKEHOUSE=false
ENABLE_METADATA=false
COMPOSE_FILES=compose/compose.core.yaml:compose/compose.analytics.yaml:compose/compose.ml.yaml:compose/compose.monitoring.yaml:compose/compose.connector_csv.yaml:compose/compose.connector_db.yaml:compose/compose.connector_shopify.yaml
ENABLED_CONNECTORS=csv,database,shopify
ENABLED_OPTIONAL_EXTRAS=reporting
