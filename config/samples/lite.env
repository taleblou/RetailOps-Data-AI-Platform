# Lite profile: core + connectors + analytics
APP_PROFILE=lite
ENABLE_CONNECTOR_CSV=true
ENABLE_ANALYTICS_KPI=true
ENABLE_FORECASTING=false
ENABLE_MONITORING=false
ENABLE_CDC=false
ENABLE_LAKEHOUSE=false
ENABLE_METADATA=false
COMPOSE_FILES=compose/compose.core.yaml:compose/compose.analytics.yaml:compose/compose.connector_csv.yaml
ENABLED_CONNECTORS=csv
ENABLED_OPTIONAL_EXTRAS=reporting
