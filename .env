POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=retailops
POSTGRES_PORT=5433

API_PORT=8000
MLFLOW_PORT=5000
METABASE_PORT=3000
# Added from profile sample
APP_PROFILE=pro
ENABLE_CONNECTOR_CSV=true
ENABLE_CONNECTOR_DB=true
ENABLE_CONNECTOR_SHOPIFY=true
ENABLE_ANALYTICS_KPI=true
ENABLE_FORECASTING=true
ENABLE_SHIPMENT_RISK=true
ENABLE_STOCKOUT_INTELLIGENCE=true
ENABLE_REORDER_ENGINE=true
ENABLE_RETURNS_INTELLIGENCE=true
ENABLE_ML_REGISTRY=true
ENABLE_MONITORING=true
ENABLE_CDC=true
ENABLE_STREAMING=true
ENABLE_LAKEHOUSE=true
ENABLE_QUERY_LAYER=true
ENABLE_METADATA=true
ENABLE_FEATURE_STORE=true
ENABLE_ADVANCED_SERVING=true
PRO_PLATFORM_ARTIFACT_DIR=data/artifacts/pro_platform
COMPOSE_FILES=compose/compose.core.yaml:compose/compose.analytics.yaml:compose/compose.ml.yaml:compose/compose.monitoring.yaml:compose/compose.cdc.yaml:compose/compose.streaming.yaml:compose/compose.lakehouse.yaml:compose/compose.query.yaml:compose/compose.metadata.yaml:compose/compose.feature_store.yaml:compose/compose.advanced_serving.yaml:compose/compose.connector_csv.yaml:compose/compose.connector_db.yaml
MINIO_BUCKET=retailops-lakehouse
DEBEZIUM_GROUP_ID=retailops-debezium

# Added from profile sample
ENABLED_CONNECTORS=csv,database
ENABLED_OPTIONAL_EXTRAS=reporting,feature-store,advanced-serving
